---
import { t, ACADEMIC_MONTHS, monthToAcademicIndex, currentAcademicYear } from '../data/content'
import type { Phase } from '../data/types'

interface Props {
  phases: Phase[]
}

const { phases } = Astro.props
if (!phases || phases.length === 0) return

const levelStyle: Record<string, { color: string; labelTa: string; labelEn: string }> = {
  registration: { color: 'var(--sage)', labelTa: 'பதிவு', labelEn: 'Registration' },
  district: { color: 'var(--teal)', labelTa: 'மாவட்டம்', labelEn: 'District' },
  state: { color: 'var(--teal)', labelTa: 'மாநிலம்', labelEn: 'State' },
  national: { color: 'var(--bronze)', labelTa: 'தேசியம்', labelEn: 'National' },
  international: { color: '#7B4F34', labelTa: 'சர்வதேசம்', labelEn: 'International' },
}

const nowGridIdx = monthToAcademicIndex(new Date().getMonth())

// Determine if registration for this year is already past — if so, show next year's schedule
const registrationPhase = phases.find((p) => p.level === 'registration') ?? phases[0]
const lastRegAcIdx = Math.max(...registrationPhase.months.map(monthToAcademicIndex))
const showNextYear = nowGridIdx > lastRegAcIdx

// Compute the year label to display (e.g. "2026–27")
const [cyStart] = currentAcademicYear().split('-')
const displayStartYear = showNextYear ? parseInt(cyStart) + 1 : parseInt(cyStart)
const displayYear = `${displayStartYear}–${String(displayStartYear + 1).slice(2)}`

// Suppress Today marker when showing next year (today falls outside the displayed year)
const effectiveNowGridIdx = showNextYear ? -1 : nowGridIdx

const usedLevels = [...new Set(phases.map((p) => p.level))]

const phaseRows = phases.map((p) => {
  const gridCells = p.months.map(monthToAcademicIndex).sort((a, b) => a - b)
  const startCol = gridCells[0]
  const endCol = gridCells[gridCells.length - 1]
  const style = levelStyle[p.level] || levelStyle.district
  return { ...p, startCol, endCol, style }
})
---

<section class="timeline">
  <div class="timeline__header">
    <div>
      <div class="timeline__kicker">
        <span class="ta">கட்ட-வாரியான காலவரிசை</span>
        <span class="en">Phase-by-phase timeline</span>
      </div>
      <div class="timeline__title">
        <span class="ta">{displayYear} கல்வியாண்டு · ஜூன் → மே</span>
        <span class="en">Academic year {displayYear} · Jun → May</span>
      </div>
      {
        showNextYear && (
          <div class="timeline__next-badge">
            <span class="ta">அடுத்த ஆண்டு அட்டவணை</span>
            <span class="en">Next year's schedule</span>
          </div>
        )
      }
    </div>
  </div>

  <!-- Month header -->
  <div class="timeline__months">
    {
      ACADEMIC_MONTHS.en.map((_, i) => (
        <div
          class:list={['timeline__month', { 'timeline__month--now': i === effectiveNowGridIdx }]}
        >
          <span class="ta">{ACADEMIC_MONTHS.ta[i]}</span>
          <span class="en">{ACADEMIC_MONTHS.en[i]}</span>
        </div>
      ))
    }
  </div>

  <!-- Phase rows -->
  <div class="timeline__rows">
    {
      phaseRows.map((p) => (
        <div class="timeline__row">
          {[...Array(12)].map((_, c) => (
            <div
              class:list={['timeline__cell', { 'timeline__cell--now': c === effectiveNowGridIdx }]}
            />
          ))}
          <div
            class="timeline__bar"
            style={`left: ${(p.startCol / 12) * 100}%; width: ${((p.endCol - p.startCol + 1) / 12) * 100}%; background: ${p.style.color};`}
            data-tip-title-ta={t(p.title, 'ta')}
            data-tip-title-en={t(p.title, 'en')}
            data-tip-note-ta={p.note ? t(p.note, 'ta') : ''}
            data-tip-note-en={p.note ? t(p.note, 'en') : ''}
          >
            <div class="timeline__bar-title">
              <span class="ta">{t(p.title, 'ta')}</span>
              <span class="en">{t(p.title, 'en')}</span>
            </div>
            {p.note && (
              <div class="timeline__bar-note">
                <span class="ta">{t(p.note, 'ta')}</span>
                <span class="en">{t(p.note, 'en')}</span>
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>

  <!-- Legend -->
  <div class="timeline__legend">
    {
      usedLevels.map((k) => {
        const v = levelStyle[k]
        return (
          <div class="timeline__legend-item">
            <span class="timeline__legend-swatch" style={`background: ${v.color};`} />
            <span class="ta">{v.labelTa}</span>
            <span class="en">{v.labelEn}</span>
          </div>
        )
      })
    }
    {
      !showNextYear && (
        <div class="timeline__legend-item timeline__legend-now">
          <span class="timeline__legend-line" />
          <span class="ta">இன்று</span>
          <span class="en">Today</span>
        </div>
      )
    }
  </div>

  <!-- Single global tooltip reused for all bars via JS -->
  <div class="timeline__tooltip" id="timeline-tooltip" aria-hidden="true" style="display:none">
    <div class="timeline__tooltip-title"></div>
    <div class="timeline__tooltip-note"></div>
  </div>
</section>

<script>
  function initTimelineTooltips() {
    const section = document.querySelector('.timeline')
    if (!section) return

    const tip = section.querySelector<HTMLElement>('#timeline-tooltip')
    if (!tip) return

    const tipTitle = tip.querySelector<HTMLElement>('.timeline__tooltip-title')!
    const tipNote = tip.querySelector<HTMLElement>('.timeline__tooltip-note')!

    const lang = () => (document.documentElement.dataset.lang === 'en' ? 'en' : 'ta')

    section.querySelectorAll<HTMLElement>('.timeline__bar').forEach((bar) => {
      bar.addEventListener('mouseenter', () => {
        const l = lang()
        const title = bar.dataset[l === 'en' ? 'tipTitleEn' : 'tipTitleTa'] || ''
        const note = bar.dataset[l === 'en' ? 'tipNoteEn' : 'tipNoteTa'] || ''
        tipTitle.textContent = title
        tipNote.textContent = note
        tipNote.style.display = note ? '' : 'none'

        const barRect = bar.getBoundingClientRect()
        const sectionRect = section.getBoundingClientRect()

        tip.style.display = 'block'
        // Position above the bar, aligned to its left edge (clamped inside section)
        const rawLeft = barRect.left - sectionRect.left
        const maxLeft = sectionRect.width - tip.offsetWidth - 4
        tip.style.left = Math.max(0, Math.min(rawLeft, maxLeft)) + 'px'
        tip.style.top = barRect.top - sectionRect.top - tip.offsetHeight - 6 + 'px'
      })

      bar.addEventListener('mouseleave', () => {
        tip.style.display = 'none'
      })
    })
  }

  // Run on first load and after every View Transition navigation
  document.addEventListener('astro:page-load', initTimelineTooltips)
</script>

<style>
  .timeline {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 16px 18px;
    margin-bottom: 20px;
    position: relative;
  }

  @media (min-width: 768px) {
    .timeline {
      padding: 26px 28px 22px;
    }
  }

  .timeline__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .timeline__kicker {
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--bronze);
    font-weight: 700;
    margin-bottom: 4px;
  }

  .timeline__title {
    font-size: 17px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.25;
  }

  :global([data-lang='ta']) .timeline__title {
    font-family: var(--font-ta);
  }

  :global([data-lang='en']) .timeline__title {
    font-family: var(--font-display);
  }

  @media (min-width: 768px) {
    .timeline__title {
      font-size: 20px;
    }
  }

  .timeline__next-badge {
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--sage);
    padding: 3px 8px;
    border: 1px solid var(--sage);
    border-radius: 999px;
    margin-top: 6px;
    display: inline-block;
  }

  :global([data-lang='ta']) .timeline__next-badge {
    font-family: var(--font-ta);
    letter-spacing: 0;
  }

  .timeline__months {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2px;
    margin-bottom: 6px;
    font-family: var(--font-ui);
  }

  .timeline__month {
    font-size: 10px;
    letter-spacing: 0.5px;
    text-align: center;
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    padding: 2px 0;
    border-top: 1px solid var(--line-soft);
  }

  .timeline__month--now {
    color: var(--bronze);
    font-weight: 700;
    border-top: 2px solid var(--bronze);
  }

  .timeline__rows {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }

  .timeline__row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2px;
    position: relative;
    min-height: 44px;
  }

  .timeline__cell {
    background: var(--ivory);
    border-radius: 2px;
    height: 44px;
  }

  .timeline__cell--now {
    background: rgba(181, 96, 58, 0.06);
  }

  .timeline__bar {
    position: absolute;
    top: 0;
    height: 44px;
    border-radius: 3px;
    padding: 6px 8px;
    color: #fff;
    font-family: var(--font-ui);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    cursor: default;
  }

  @media (min-width: 768px) {
    .timeline__bar {
      padding: 6px 10px;
    }
  }

  .timeline__bar-title {
    font-size: 10px;
    font-weight: 600;
    line-height: 1.15;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  :global([data-lang='ta']) .timeline__bar-title {
    font-family: var(--font-ta);
  }

  @media (min-width: 768px) {
    .timeline__bar-title {
      font-size: 11.5px;
    }
  }

  .timeline__bar-note {
    font-size: 10px;
    opacity: 0.85;
    line-height: 1.2;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
    margin-top: 1px;
    display: none;
  }

  @media (min-width: 768px) {
    .timeline__bar-note {
      display: block;
    }
  }

  :global([data-lang='ta']) .timeline__bar-note {
    font-family: var(--font-ta);
  }

  .timeline__tooltip {
    position: absolute;
    z-index: 20;
    background: var(--ink);
    color: #fff;
    border-radius: 4px;
    padding: 6px 10px;
    white-space: nowrap;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
    font-family: var(--font-ui);
  }

  .timeline__tooltip-title {
    font-size: 11.5px;
    font-weight: 600;
    line-height: 1.25;
  }

  :global([data-lang='ta']) .timeline__tooltip-title {
    font-family: var(--font-ta);
  }

  .timeline__tooltip-note {
    font-size: 10.5px;
    opacity: 0.82;
    margin-top: 2px;
    line-height: 1.3;
  }

  :global([data-lang='ta']) .timeline__tooltip-note {
    font-family: var(--font-ta);
  }

  .timeline__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft);
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--muted);
  }

  @media (min-width: 768px) {
    .timeline__legend {
      gap: 18px;
    }
  }

  .timeline__legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  :global([data-lang='ta']) .timeline__legend-item {
    font-family: var(--font-ta);
  }

  .timeline__legend-swatch {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .timeline__legend-now {
    margin-left: auto;
    opacity: 0.85;
  }

  .timeline__legend-line {
    width: 10px;
    height: 2px;
    background: var(--bronze);
    display: inline-block;
  }
</style>
