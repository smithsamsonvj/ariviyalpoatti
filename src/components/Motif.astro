---
interface Props {
  size?: number
  color?: string
  opacity?: number
}

const { size = 20, color = 'var(--bronze)', opacity = 0.7 } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 20 20"
  style={`opacity: ${opacity}; flex-shrink: 0;`}
  aria-hidden="true"
>
  <rect
    x="3"
    y="3"
    width="14"
    height="14"
    fill="none"
    stroke={color}
    stroke-width="0.6"
    transform="rotate(45 10 10)"></rect>
  <circle cx="10" cy="3" r="0.9" fill={color}></circle>
  <circle cx="10" cy="17" r="0.9" fill={color}></circle>
  <circle cx="3" cy="10" r="0.9" fill={color}></circle>
  <circle cx="17" cy="10" r="0.9" fill={color}></circle>
  <circle cx="10" cy="10" r="1.1" fill={color}></circle>
</svg>
