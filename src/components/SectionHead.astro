---
interface Props {
  titleTa: string
  titleEn: string
}

const { titleTa, titleEn } = Astro.props
---

<div class="section-head">
  <span class="section-head__rule"></span>
  <h2>
    <span class="ta">{titleTa}</span>
    <span class="en">{titleEn}</span>
  </h2>
</div>

<style>
  .section-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .section-head__rule {
    width: 14px;
    height: 2px;
    background: var(--bronze);
    flex-shrink: 0;
  }

  h2 {
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  :global([data-lang='ta']) h2 {
    font-family: var(--font-ta);
    font-size: 18px;
  }

  :global([data-lang='en']) h2 {
    font-family: var(--font-display);
  }

  @media (min-width: 768px) {
    h2 {
      font-size: 24px;
    }

    :global([data-lang='ta']) h2 {
      font-size: 22px;
    }
  }
</style>
