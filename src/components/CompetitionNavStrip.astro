---
interface NavComp {
  id: string
  data: {
    name: { ta: string; en: string }
    shortName: { ta: string; en: string }
    category: string
  }
}

interface Props {
  prevComp: NavComp | null
  nextComp: NavComp | null
  position: { current: number; total: number }
}

const { prevComp, nextComp, position } = Astro.props
const prevUrl = prevComp ? `/competitions/${prevComp.id}` : null
const nextUrl = nextComp ? `/competitions/${nextComp.id}` : null
---

<nav
  class="nav-strip"
  aria-label="Competition navigation"
  data-nav-strip
  data-prev-url={prevUrl ?? ''}
  data-next-url={nextUrl ?? ''}
>
  <!-- Prev -->
  {
    prevComp ? (
      <a
        href={prevUrl}
        class="nav-strip__cell nav-strip__cell--prev"
        data-nav-dir="backward"
        data-astro-prefetch
      >
        <span class="nav-strip__arrow nav-strip__arrow--left">←</span>
        <span class="nav-strip__inner">
          <span class="nav-strip__label">
            <span class="ta">முந்தையது</span>
            <span class="en">Previous</span>
          </span>
          <span class="nav-strip__name">
            <span class="ta">{prevComp.data.name.ta}</span>
            <span class="en">{prevComp.data.name.en}</span>
          </span>
        </span>
      </a>
    ) : (
      <span class="nav-strip__cell nav-strip__cell--prev nav-strip__cell--empty" />
    )
  }

  <!-- Position counter -->
  <span class="nav-strip__counter" aria-label={`${position.current} of ${position.total}`}>
    {position.current} / {position.total}
  </span>

  <!-- Next -->
  {
    nextComp ? (
      <a
        href={nextUrl}
        class="nav-strip__cell nav-strip__cell--next"
        data-nav-dir="forward"
        data-astro-prefetch
      >
        <span class="nav-strip__inner">
          <span class="nav-strip__label">
            <span class="ta">அடுத்தது</span>
            <span class="en">Next</span>
          </span>
          <span class="nav-strip__name">
            <span class="ta">{nextComp.data.name.ta}</span>
            <span class="en">{nextComp.data.name.en}</span>
          </span>
        </span>
        <span class="nav-strip__arrow nav-strip__arrow--right">→</span>
      </a>
    ) : (
      <span class="nav-strip__cell nav-strip__cell--next nav-strip__cell--empty" />
    )
  }
</nav>

<style>
  .nav-strip {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    margin-top: 48px;
    padding: 20px 0 8px;
    border-top: 1px solid var(--line);
  }

  .nav-strip__cell {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    transition:
      background 0.15s ease,
      transform 0.15s ease;
    min-height: 64px;
  }

  .nav-strip__cell--empty {
    pointer-events: none;
  }

  .nav-strip__cell--prev {
    justify-content: flex-start;
  }

  .nav-strip__cell--next {
    justify-content: flex-end;
    text-align: right;
  }

  .nav-strip__cell:hover {
    background: var(--cream);
  }

  .nav-strip__cell--prev:hover .nav-strip__arrow--left {
    transform: translateX(-4px);
  }

  .nav-strip__cell--next:hover .nav-strip__arrow--right {
    transform: translateX(4px);
  }

  .nav-strip__inner {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .nav-strip__label {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--sage);
  }

  :global([data-lang='ta']) .nav-strip__label {
    font-family: var(--font-ta);
    letter-spacing: 0;
  }

  .nav-strip__name {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }

  :global([data-lang='ta']) .nav-strip__name {
    font-family: var(--font-ta);
  }

  .nav-strip__arrow {
    font-size: 20px;
    color: var(--sage);
    flex-shrink: 0;
    display: inline-block;
    transition: transform 0.15s ease;
    line-height: 1;
  }

  .nav-strip__counter {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
    padding: 4px 8px;
    text-align: center;
  }

  /* Mobile: stack vertically, next on top */
  @media (max-width: 639px) {
    .nav-strip {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      gap: 4px;
    }

    .nav-strip__cell--next {
      order: -1;
      justify-content: space-between;
      text-align: left;
    }

    .nav-strip__cell--prev {
      justify-content: space-between;
    }

    .nav-strip__counter {
      order: 1;
      text-align: center;
      padding: 8px 0 0;
    }

    .nav-strip__cell {
      padding: 14px 16px;
      min-height: 56px;
    }
  }
</style>
