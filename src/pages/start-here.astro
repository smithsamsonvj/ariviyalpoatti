---
import Base from '../layouts/Base.astro'
import Motif from '../components/Motif.astro'
import QuickReferenceCard from '../components/QuickReferenceCard.astro'
import { COPY } from '../data/content'

const roles = [
  {
    id: 'teacher',
    label: COPY.audiences.teacher.label,
    color: 'var(--teal)',
    steps: COPY.startHere.teacher,
  },
  {
    id: 'principal',
    label: COPY.audiences.principal.label,
    color: 'var(--bronze)',
    steps: COPY.startHere.principal,
  },
  {
    id: 'parent',
    label: COPY.audiences.parent.label,
    color: 'var(--sage)',
    steps: COPY.startHere.parent,
  },
]
---

<Base title="இங்கே தொடங்குங்கள் — Start Here" currentRoute="/start-here">
  <div class="start-page">
    <div class="start-page__header">
      <div class="start-page__kicker">
        <Motif size={16} color="var(--bronze)" opacity={0.7} />
        <span>
          <span class="ta">இங்கே தொடங்குங்கள்</span>
          <span class="en">Start Here</span>
        </span>
      </div>
      <h1 class="start-page__title">
        <span class="ta">{COPY.startHere.title.ta}</span>
        <span class="en">{COPY.startHere.title.en}</span>
      </h1>
      <p class="start-page__sub">
        <span class="ta">{COPY.startHere.intro.ta}</span>
        <span class="en">{COPY.startHere.intro.en}</span>
      </p>
    </div>

    <!-- Tab bar -->
    <div class="start-page__tabs" role="tablist">
      {
        roles.map((role, i) => (
          <button
            class:list={['start-page__tab', { 'start-page__tab--active': i === 0 }]}
            data-tab-btn={role.id}
            style={`--tab-color: ${role.color};`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${role.id}`}
          >
            <span class="ta">{role.label.ta}</span>
            <span class="en">{role.label.en}</span>
          </button>
        ))
      }
    </div>

    <!-- Tab panels -->
    {
      roles.map((role, i) => (
        <div
          class="start-page__panel"
          id={`panel-${role.id}`}
          data-tab-panel={role.id}
          role="tabpanel"
          hidden={i !== 0}
        >
          <ol class="start-page__steps" style={`--step-color: ${role.color};`}>
            {role.steps.map((step, j) => (
              <li class="start-page__step">
                <span class="start-page__step-num">{String(j + 1).padStart(2, '0')}</span>
                <span class="start-page__step-text">
                  <span class="ta">{step.ta}</span>
                  <span class="en">{step.en}</span>
                </span>
              </li>
            ))}
          </ol>

          <div class="start-page__actions">
            <a
              href="/competitions"
              class="start-page__btn-primary"
              style={`background: ${role.color};`}
            >
              <span class="ta">போட்டிகளைப் பார் →</span>
              <span class="en">See competitions →</span>
            </a>
            <a
              href="/key-dates"
              class="start-page__btn-secondary"
              style={`color: ${role.color}; border-color: ${role.color};`}
            >
              <span class="ta">காலக்கெடுகளைப் பார்</span>
              <span class="en">See deadlines</span>
            </a>
          </div>
        </div>
      ))
    }

    <!-- Quick Reference Card -->
    <QuickReferenceCard />
  </div>
</Base>

<style>
  .start-page {
    padding: var(--section-pad) var(--gutter);
    max-width: 820px;
    margin: 0 auto;
  }

  .start-page__header {
    margin-bottom: 28px;
  }

  .start-page__kicker {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .start-page__title {
    font-size: 32px;
    font-weight: 400;
    margin: 0 0 10px;
    line-height: 1.15;
  }

  :global([data-lang='ta']) .start-page__title {
    font-family: var(--font-ta);
    font-size: 26px;
  }

  :global([data-lang='en']) .start-page__title {
    font-family: var(--font-display);
  }

  @media (min-width: 768px) {
    .start-page__title {
      font-size: 44px;
    }

    :global([data-lang='ta']) .start-page__title {
      font-size: 34px;
    }
  }

  .start-page__sub {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
  }

  :global([data-lang='ta']) .start-page__sub {
    font-family: var(--font-ta);
  }

  /* Tabs */
  .start-page__tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 28px;
  }

  .start-page__tab {
    padding: 12px 20px;
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    transition: all 0.12s;
    min-height: 44px;
    min-width: auto;
    cursor: pointer;
  }

  :global([data-lang='ta']) .start-page__tab {
    font-family: var(--font-ta);
    font-size: 15px;
  }

  .start-page__tab:hover {
    color: var(--ink);
  }

  .start-page__tab--active {
    color: var(--ink);
    border-bottom-color: var(--tab-color);
  }

  /* Steps */
  .start-page__steps {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 28px;
  }

  .start-page__step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .start-page__step-num {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--step-color);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    min-width: 36px;
  }

  @media (min-width: 768px) {
    .start-page__step-num {
      font-size: 40px;
      min-width: 48px;
    }
  }

  .start-page__step-text {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
    padding-top: 6px;
  }

  :global([data-lang='ta']) .start-page__step-text {
    font-family: var(--font-ta);
  }

  @media (min-width: 768px) {
    .start-page__step-text {
      font-size: 16px;
      padding-top: 10px;
    }
  }

  /* Actions */
  .start-page__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .start-page__btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    color: var(--ivory);
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 600;
    min-height: 44px;
    min-width: auto;
    transition: opacity 0.12s;
  }

  :global([data-lang='ta']) .start-page__btn-primary {
    font-family: var(--font-ta);
  }

  .start-page__btn-primary:hover {
    opacity: 0.9;
  }

  .start-page__btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border: 1px solid;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    min-height: 44px;
    min-width: auto;
    transition: opacity 0.12s;
  }

  :global([data-lang='ta']) .start-page__btn-secondary {
    font-family: var(--font-ta);
  }
</style>

<script>
  function initTabs() {
    const buttons = document.querySelectorAll('[data-tab-btn]')
    const panels = document.querySelectorAll('[data-tab-panel]')

    // Read URL param
    const params = new URLSearchParams(window.location.search)
    const forParam = params.get('for')
    if (forParam) {
      const targetBtn = document.querySelector(`[data-tab-btn="${forParam}"]`)
      if (targetBtn) {
        activateTab(forParam)
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tabId = (btn as HTMLElement).dataset.tabBtn!
        activateTab(tabId)
      })
    })

    function activateTab(tabId: string) {
      buttons.forEach((b) => {
        const isActive = (b as HTMLElement).dataset.tabBtn === tabId
        b.classList.toggle('start-page__tab--active', isActive)
        b.setAttribute('aria-selected', String(isActive))
      })
      panels.forEach((p) => {
        ;(p as HTMLElement).hidden = (p as HTMLElement).dataset.tabPanel !== tabId
      })
    }
  }

  initTabs()
  document.addEventListener('astro:after-swap', initTabs)
</script>
