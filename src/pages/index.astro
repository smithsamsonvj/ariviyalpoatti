---
import Base from '../layouts/Base.astro'
import Motif from '../components/Motif.astro'
import AudienceCard from '../components/AudienceCard.astro'
import EscapeLink from '../components/EscapeLink.astro'
import { COPY, fmtDate } from '../data/content'
import lastRun from '../data/last-run.json'

const siteVerified = lastRun.date
---

<Base title="அறிவியல் போட்டி — Ariviyal Poatti" currentRoute="/" hideFooter>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__motifs">
      <Motif size={22} color="var(--ivory)" opacity={0.7} />
      <Motif size={18} color="var(--ivory)" opacity={0.4} />
    </div>

    <div class="hero__kicker">
      <span class="ta">{COPY.home.heroKicker.ta}</span>
      <span class="en">{COPY.home.heroKicker.en}</span>
    </div>

    <h1 class="hero__title">
      <span class="ta">{COPY.home.heroTitle.ta}</span>
      <span class="en">{COPY.home.heroTitle.en}</span>
    </h1>

    <p class="hero__sub">
      <span class="ta">{COPY.home.heroSub.ta}</span>
      <span class="en">{COPY.home.heroSub.en}</span>
    </p>

    <div class="hero__verified">
      <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
        <circle cx="5" cy="5" r="4" fill="none" stroke="currentColor" stroke-width="1.3"></circle>
        <path
          d="M3 5.2l1.4 1.4L7.2 3.8"
          fill="none"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span class="hero__verified-label">
        <span class="ta">சரிபார்க்கப்பட்டது</span>
        <span class="en">Verified</span>
      </span>
      <span class="hero__verified-sep">&middot;</span>
      <span class="hero__verified-date">
        <span class="ta">{fmtDate(siteVerified, 'ta')}</span>
        <span class="en">{fmtDate(siteVerified, 'en')}</span>
      </span>
    </div>
  </section>

  <!-- Role prompt -->
  <section class="role-prompt">
    <div class="role-prompt__label">
      <span class="role-prompt__line"></span>
      <span>
        <span class="ta">இங்கே தொடங்குங்கள்</span>
        <span class="en">Start here</span>
      </span>
    </div>
    <h2 class="role-prompt__title">
      <span class="ta"
        >{COPY.audiences.teacher.label.ta}? {COPY.audiences.principal.label.ta}? {
          COPY.audiences.parent.label.ta
        }?</span
      >
      <span class="en">{COPY.home.audiencePrompt.en}</span>
    </h2>
    <p class="role-prompt__body">
      <span class="ta"
        >ஒரு பாத்திரத்தைத் தேர்ந்தெடுங்கள். உங்களுக்கான படிகளை மட்டும் காட்டுவோம் — காலண்டர்,
        கடிதங்கள், அடுத்த செயல்.</span
      >
      <span class="en"
        >Pick a role. We'll walk you through only the steps that matter to you — dates, forms, next
        action.</span
      >
    </p>
  </section>

  <!-- Role cards -->
  <section class="role-cards">
    <AudienceCard
      role="teacher"
      labelTa={COPY.audiences.teacher.label.ta}
      labelEn={COPY.audiences.teacher.label.en}
      detailTa={COPY.audiences.teacher.detail.ta}
      detailEn={COPY.audiences.teacher.detail.en}
    />
    <AudienceCard
      role="principal"
      labelTa={COPY.audiences.principal.label.ta}
      labelEn={COPY.audiences.principal.label.en}
      detailTa={COPY.audiences.principal.detail.ta}
      detailEn={COPY.audiences.principal.detail.en}
    />
    <AudienceCard
      role="parent"
      labelTa={COPY.audiences.parent.label.ta}
      labelEn={COPY.audiences.parent.label.en}
      detailTa={COPY.audiences.parent.detail.ta}
      detailEn={COPY.audiences.parent.detail.en}
    />
  </section>

  <!-- Escape hatches -->
  <section class="escape-section">
    <div class="escape-section__label">
      <span class="escape-section__line"></span>
      <span>
        <span class="ta">அல்லது, நேரடியாக</span>
        <span class="en">Or jump straight to</span>
      </span>
    </div>
    <div class="escape-section__grid">
      <EscapeLink
        href="/competitions"
        titleTa="போட்டிகளையும் பார்"
        titleEn="All competitions"
        subtitleTa="பட்டியல் + வடிகட்டி"
        subtitleEn="List + filter"
      />
      <EscapeLink
        href="/key-dates"
        titleTa="வருடாந்திர காலண்டர்"
        titleEn="Annual calendar"
        subtitleTa="அனைத்து காலக்கெடுகள்"
        subtitleEn="Every deadline"
      />
      <EscapeLink
        href="/why-this-exists"
        titleTa="இது ஏன் இருக்கிறது"
        titleEn="Why this exists"
        subtitleTa="தமிழ்நாடு எண்களில்"
        subtitleEn="Tamil Nadu in numbers"
      />
    </div>
  </section>

  <!-- Home mini-footer -->
  <footer class="home-footer">
    <div class="home-footer__text">
      <span class="ta">{COPY.home.footerNote.ta}</span>
      <span class="en">{COPY.home.footerNote.en}</span>
    </div>
  </footer>
</Base>

<style>
  /* Hero */
  .hero {
    background: var(--teal);
    color: var(--ivory);
    padding: 34px var(--gutter) 40px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 68px var(--gutter) 76px;
    }
  }

  .hero__motifs {
    position: absolute;
    top: 18px;
    right: 18px;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero__motifs {
      top: 28px;
      right: 44px;
    }
  }

  .hero__kicker {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.68;
    margin-bottom: 16px;
  }

  @media (min-width: 768px) {
    .hero__kicker {
      margin-bottom: 22px;
    }
  }

  .hero__title {
    font-weight: 400;
    margin: 0;
    max-width: 820px;
    font-size: 34px;
    line-height: 1.08;
  }

  :global([data-lang='ta']) .hero__title {
    font-family: var(--font-ta);
    font-size: 28px;
    line-height: 1.3;
  }

  :global([data-lang='en']) .hero__title {
    font-family: var(--font-display);
    letter-spacing: -0.5px;
  }

  @media (min-width: 768px) {
    .hero__title {
      font-size: 58px;
    }

    :global([data-lang='ta']) .hero__title {
      font-size: 44px;
    }
  }

  .hero__sub {
    font-size: 15px;
    line-height: 1.55;
    opacity: 0.82;
    max-width: 600px;
    margin-top: 16px;
    margin-bottom: 0;
  }

  :global([data-lang='ta']) .hero__sub {
    font-family: var(--font-ta);
  }

  @media (min-width: 768px) {
    .hero__sub {
      font-size: 17px;
      margin-top: 22px;
    }

    :global([data-lang='ta']) .hero__sub {
      font-size: 18px;
    }
  }

  .hero__verified {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.5px;
    opacity: 0.72;
    margin-top: 22px;
    padding: 6px 12px;
    border: 1px solid rgba(245, 240, 232, 0.25);
    border-radius: 999px;
  }

  @media (min-width: 768px) {
    .hero__verified {
      margin-top: 30px;
    }
  }

  .hero__verified-label {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .hero__verified-sep {
    opacity: 0.55;
  }

  .hero__verified-date {
    font-variant-numeric: tabular-nums;
  }

  /* Role prompt */
  .role-prompt {
    padding: 32px var(--gutter) 14px;
  }

  @media (min-width: 768px) {
    .role-prompt {
      padding: 56px var(--gutter) 18px;
    }
  }

  .role-prompt__label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bronze);
    font-weight: 600;
  }

  .role-prompt__line {
    width: 24px;
    height: 1px;
    background: var(--bronze);
  }

  .role-prompt__title {
    font-weight: 400;
    margin: 0;
    max-width: 680px;
    font-size: 28px;
    line-height: 1.12;
  }

  :global([data-lang='ta']) .role-prompt__title {
    font-family: var(--font-ta);
    font-size: 24px;
  }

  :global([data-lang='en']) .role-prompt__title {
    font-family: var(--font-display);
  }

  @media (min-width: 768px) {
    .role-prompt__title {
      font-size: 42px;
    }

    :global([data-lang='ta']) .role-prompt__title {
      font-size: 36px;
    }
  }

  .role-prompt__body {
    font-size: 14px;
    color: var(--muted);
    margin-top: 12px;
    margin-bottom: 0;
    max-width: 560px;
    line-height: 1.55;
  }

  :global([data-lang='ta']) .role-prompt__body {
    font-family: var(--font-ta);
  }

  @media (min-width: 768px) {
    .role-prompt__body {
      font-size: 16px;
    }
  }

  /* Role cards */
  .role-cards {
    padding: 18px var(--gutter) 36px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  @media (min-width: 768px) {
    .role-cards {
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      padding: 18px var(--gutter) 64px;
    }
  }

  /* Escape section */
  .escape-section {
    padding: 0 var(--gutter) 36px;
  }

  @media (min-width: 768px) {
    .escape-section {
      padding: 0 var(--gutter) 56px;
    }
  }

  .escape-section__label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }

  .escape-section__line {
    width: 24px;
    height: 1px;
    background: var(--line);
  }

  .escape-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  @media (min-width: 768px) {
    .escape-section__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
  }

  /* Home mini-footer */
  .home-footer {
    padding: 20px var(--gutter) 28px;
    background: var(--ink);
    color: var(--ivory);
  }

  @media (min-width: 768px) {
    .home-footer {
      padding: 32px var(--gutter) 40px;
    }
  }

  .home-footer__text {
    font-size: 12px;
    opacity: 0.5;
    max-width: 640px;
    line-height: 1.6;
  }

  :global([data-lang='ta']) .home-footer__text {
    font-family: var(--font-ta);
  }
</style>
